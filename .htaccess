# Disable MultiViews - this can cause routing issues
Options -MultiViews

# Force rewrite engine to use the correct base
RewriteBase /ettv/

Options -Indexes
AddDefaultCharset UTF-8
RewriteEngine On

# Let real files and folders load directly — no redirect
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Only redirect truly missing paths to index.php
RewriteRule ^(.*)$ index.php [QSA,L]

<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
</IfModule>